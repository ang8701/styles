        $xoredBytes = [System.Convert]::FromBase64String($XoredB64Response)
        $keyBytes = [System.Text.Encoding]::UTF8.GetBytes($Key)
        $b64Bytes = New-Object byte[] $xoredBytes.Length

        # Perform XOR Decryption to recover the original Base64 string
